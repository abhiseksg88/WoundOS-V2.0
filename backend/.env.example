# WoundOS V2 Backend Environment Variables
# Copy to .env and fill in values

# GCP Configuration
WOUNDOS_GCP_PROJECT_ID=wound-ai-api
WOUNDOS_GCP_PROJECT_NUMBER=333499614175
WOUNDOS_GCP_REGION=us-central1

# Cloud Storage
WOUNDOS_GCS_BUCKET=woundos-scans
WOUNDOS_GCS_SPLAT_BUCKET=woundos-splats

# Firestore
WOUNDOS_FIRESTORE_COLLECTION=jobs

# Pub/Sub
WOUNDOS_PUBSUB_TOPIC=scan-jobs
WOUNDOS_PUBSUB_SUBSCRIPTION=scan-jobs-worker

# Worker Mode: "api" (no GPU), "gpu" (worker only), "all" (both)
WOUNDOS_WORKER_MODE=all

# Model Paths (inside Docker container)
WOUNDOS_DEPTH_PRO_MODEL_PATH=/models/depth_pro
WOUNDOS_SAM2_MODEL_PATH=/models/sam2
WOUNDOS_SAM2_CONFIG=sam2.1_hiera_l.yaml
WOUNDOS_SAM2_CHECKPOINT=sam2.1_hiera_large.pt

# Claude API (for clinical summaries)
WOUNDOS_ANTHROPIC_API_KEY=sk-ant-xxxxx
WOUNDOS_ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# COLMAP
WOUNDOS_COLMAP_BINARY=colmap
WOUNDOS_COLMAP_MAX_IMAGE_SIZE=1600
WOUNDOS_COLMAP_GPU_INDEX=0

# Server
WOUNDOS_HOST=0.0.0.0
WOUNDOS_PORT=8080
